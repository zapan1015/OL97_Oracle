# ======================================================================
#  .gitattributes – 줄바꿈 통일 (Windows/Linux/Mac 혼용 환경)
# ======================================================================

# 기본: 텍스트 파일은 LF로 정규화
* text=auto eol=lf

# 명시적 텍스트 파일 (LF 강제)
*.yml        text eol=lf
*.yaml       text eol=lf
*.ini        text eol=lf
*.cfg        text eol=lf
*.j2         text eol=lf
*.sh         text eol=lf
*.py         text eol=lf
*.rb         text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.json       text eol=lf
Vagrantfile  text eol=lf
.gitignore   text eol=lf

# 셸 스크립트 – 실행 권한 + LF 보장
scripts/*.sh text eol=lf

# 바이너리 파일 (줄바꿈 변환 안 함)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.pem  binary
*.key  binary
*.p12  binary
